  "keyFeatures": [
    "OpenGL hardware-accelerated 3D renderer with BSP worlds and dynamic lighting",
    "QVM (Quake Virtual Machine) bytecode system for sandboxed game logic",
    "Client-server architecture with delta-compressed snapshot networking",
    "Botlib AI system with AAS (Area Awareness System) pathfinding",
    "Multiple game types: FFA, Tournament, Team Deathmatch, CTF, and more",
    "Q3Radiant map editor and q3map BSP compiler toolchain",
    "LCC retargetable C compiler producing QVM bytecode",
    "Cross-platform support: Windows, GNU/Linux, and macOS"
  ],
  "publicApiSurface": [
    "refexport_t — Renderer module export API (tr_public.h)",
    "refimport_t — Renderer module import API (tr_public.h)",
    "gameExport_t — Game module export API (g_public.h)",
    "gameImport_t — Game module import API (g_public.h)",
    "cgameExport_t — Client game module export API (cg_public.h)",
    "Pmove() — Player movement simulation (bg_public.h)",
    "VM_Call() — QVM system call interface (vm_local.h)",
    "Cvar_Set/Get — Console variable system (qcommon.h)",
    "FS_ReadFile/WriteFile — Virtual filesystem API (qcommon.h)",
    "MSG_Write*/MSG_Read* — Network message serialization (qcommon.h)"
  ]
